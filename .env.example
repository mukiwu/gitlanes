# GitLanes no longer uses environment variables for AI keys.
# Configure your AI provider and API key inside the app via the gear menu
# → "AI Settings". Keys are stored in the OS keychain, never on disk.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
